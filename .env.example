# =============================================================================
# PV Platform - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/pv-platform?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/pv-platform?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# JWT & Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production
REFRESH_TOKEN_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# OAuth - Google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback

# -----------------------------------------------------------------------------
# OAuth - GitHub
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/oauth/github/callback

# -----------------------------------------------------------------------------
# Client URLs
# -----------------------------------------------------------------------------
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------
API_GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:5000
MEDIA_SERVICE_URL=http://localhost:5001
NOTIFICATION_SERVICE_URL=http://localhost:5002
SEARCH_SERVICE_URL=http://localhost:5003
ANALYTICS_SERVICE_URL=http://localhost:5004
PORTFOLIO_SERVICE_URL=http://localhost:5005
CAREER_SERVICE_URL=http://localhost:5006
RESUME_SERVICE_URL=http://localhost:5007
LEARNING_SERVICE_URL=http://localhost:5008
CRM_SERVICE_URL=http://localhost:5009
FINANCE_SERVICE_URL=http://localhost:5010
MARKETPLACE_SERVICE_URL=http://localhost:5011
BLOG_SERVICE_URL=http://localhost:5012
BUILDHUB_SERVICE_URL=http://localhost:5013

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# Cloudinary (Media Storage)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# -----------------------------------------------------------------------------
# Email Service (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@pvplatform.com
FROM_NAME=PV Platform

# -----------------------------------------------------------------------------
# SMS Service (Twilio)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Push Notifications (Firebase)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# -----------------------------------------------------------------------------
# Discord Integration
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# -----------------------------------------------------------------------------
# WhatsApp Business API
# -----------------------------------------------------------------------------
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY=your-github-private-key

# -----------------------------------------------------------------------------
# Google Integration
# -----------------------------------------------------------------------------
GOOGLE_WEBHOOK_SECRET=your-google-webhook-secret

# -----------------------------------------------------------------------------
# Salesforce Integration
# -----------------------------------------------------------------------------
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_USERNAME=your-salesforce-username
SALESFORCE_PASSWORD=your-salesforce-password
SALESFORCE_SECURITY_TOKEN=your-salesforce-security-token

# -----------------------------------------------------------------------------
# Redis (Caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty

# -----------------------------------------------------------------------------
# Monitoring (Future)
# -----------------------------------------------------------------------------
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=4000
AI_SERVICE_PORT=5000
MEDIA_SERVICE_PORT=5001
NOTIFICATION_SERVICE_PORT=5002
SEARCH_SERVICE_PORT=5003
ANALYTICS_SERVICE_PORT=5004
PORTFOLIO_SERVICE_PORT=5005
CAREER_SERVICE_PORT=5006
RESUME_SERVICE_PORT=5007
LEARNING_SERVICE_PORT=5008
CRM_SERVICE_PORT=5009
FINANCE_SERVICE_PORT=5010
MARKETPLACE_SERVICE_PORT=5011
BLOG_SERVICE_PORT=5012
BUILDHUB_SERVICE_PORT=5013

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_AI_FEATURES=true
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_SEARCH=true
ENABLE_OAUTH=true
ENABLE_REGISTRATION=true

# -----------------------------------------------------------------------------
# AI Configuration
# -----------------------------------------------------------------------------
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-1.5-flash
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# -----------------------------------------------------------------------------
# Media Configuration
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300

# -----------------------------------------------------------------------------
# Notification Configuration
# -----------------------------------------------------------------------------
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=1000
NOTIFICATION_MAX_RETRY_DELAY=30000

# -----------------------------------------------------------------------------
# Search Configuration
# -----------------------------------------------------------------------------
SEARCH_MAX_RESULTS=50
SEARCH_MIN_SCORE=1
SEARCH_SUGGESTION_LIMIT=10

# -----------------------------------------------------------------------------
# Analytics Configuration
# -----------------------------------------------------------------------------
ANALYTICS_MAX_EVENTS=100000
ANALYTICS_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=your-docker-registry
DOCKER_IMAGE_PREFIX=pv-platform

# -----------------------------------------------------------------------------
# Webhook Secrets
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=your-webhook-secret-key