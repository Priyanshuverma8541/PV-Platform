{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "**/.env.local",
    "**/.env"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true
    },
    "build": {
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "outputs": [
        ".eslintcache"
      ],
      "cache": true
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "cache": true,
      "dependsOn": [
        "^build"
      ]
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": [
        "build"
      ]
    },
    "type-check": {
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
