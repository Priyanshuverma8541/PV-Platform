{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "useDefineForClassFields":  true,
                            "lib":  [
                                        "DOM",
                                        "DOM.Iterable",
                                        "ES2020"
                                    ],
                            "allowJs":  false,
                            "skipLibCheck":  true,
                            "esModuleInterop":  true,
                            "module":  "ESNext",
                            "moduleResolution":  "bundler",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "noEmit":  true,
                            "strict":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "jsx":  "react-jsx",
                            "types":  [
                                          "vite/client"
                                      ],
                            "allowImportingTsExtensions":  true,
                            "typeRoots":  [
                                              "./node_modules/@types",
                                              "../../node_modules/@types"
                                          ]
                        },
    "include":  [
                    "src/**/*",
                    "vite.config.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}
